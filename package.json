{
  "name": "nov-17-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:core",
    "dev:core": "npx kill-port 5173 4000 2>/dev/null || true; npx concurrently --kill-others-on-fail \"npm run api\" \"vite\"",
    "build": "vite build && node scripts/update-htaccess.js && node scripts/verify-build.js",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "npm run test:run && cd backend/api && npm run test",
    "test:miner": "cd backend/miner_server && bash run_tests.sh",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "trading-bot:server": "node scripts/start-trading-bot-server.js",
    "trading-bot:smoke": "node scripts/smoke-trading-bot-api.js",
    "miner:server": "node scripts/start-miner-server.js",
    "api": "cd backend/api && npm run dev"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@nivo/treemap": "^0.99.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-query": "^5.90.21",
    "apexcharts": "^5.3.6",
    "autoprefixer": "^10.4.22",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-financial": "^0.2.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "date-fns": "^4.1.0",
    "lightweight-charts": "^5.0.9",
    "lodash": "^4.17.21",
    "lucide-react": "^0.564.0",
    "pdfjs-dist": "^5.4.394",
    "postcss": "^8.5.6",
    "preline": "^3.2.3",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-pdf": "^10.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^3.4.1",
    "vite": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
