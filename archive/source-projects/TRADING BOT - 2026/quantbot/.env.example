QUANTBOT_MODE=paper
# Data feed: yahoo (default), barchart, massive, or finnhub
QUANTBOT_DATA_FEED_PROVIDER=yahoo
# Required when using MASSIVE (Polygon.io)
# QUANTBOT_MASSIVE_API_KEY=your_massive_api_key
# Required when using Finnhub
# QUANTBOT_FINNHUB_API_KEY=your_finnhub_api_key
# Required when using Barchart OnDemand
# QUANTBOT_BARCHART_API_KEY=your_barchart_api_key
QUANTBOT_IB_HOST=127.0.0.1
QUANTBOT_IB_PORT=7497
QUANTBOT_IB_CLIENT_ID=1
QUANTBOT_IB_ACCOUNT=
# Optional: Telegram/Discord for alerts
# QUANTBOT_TELEGRAM_BOT_TOKEN=
# QUANTBOT_TELEGRAM_CHAT_ID=
# QUANTBOT_DISCORD_WEBHOOK=
