# Postgres connection (required).
# To use the same Postgres as the main web app (e.g. port 5433, database algonov26):
#   DATABASE_URL=postgresql://localhost:5433/algonov26
#   Then run from this project root: alembic upgrade head
# Standalone example:
DATABASE_URL=postgresql://user:password@localhost:5432/sentiment_db

# Reddit API (optional; Reddit gatherer no-ops if missing)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=SentimentIndicator/1.0

# Optional
SENTIMENT_SYMBOLS=AAPL,BTC
SCHEDULER_INTERVAL_MINUTES=15

# On-demand sentiment providers (for symbol lookup; keys only in backend, never in frontend)
MASSIVE_API_KEY=your_massive_api_key
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Debug
# SQL_ECHO=true
